{
  "manifest_version": 3,
  "name": "Qiita Dark Mode",
  "description": "Qiitaのダークモード",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "assets/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.qiita.com/*"],
      "js": [
        "assets/js/logger.js",
        "assets/js/config.js",
        "assets/js/utils.js",
        "assets/js/content.js"
      ],
      "css": ["assets/css/theme.css"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["*://*.qiita.com/*"]
}
